# API base URL
VITE_API_BASE_URL=
# API prefix path
VITE_API_PREFIX=

# Recommended for production on Cloudflare Pages:
# leave VITE_API_BASE_URL empty, set VITE_API_PREFIX=/api,
# and configure API_BASE_URL in Pages env vars for the Functions proxy.
API_BASE_URL=https://api.bingka.net

# CDN URL for static assets
VITE_CDN_URL=https://cdn.jsdmirror.com

# Enable tutorial document feature (true/false)
VITE_TUTORIAL_DOCUMENT=true

# Default login credentials (for development only)
VITE_USER_EMAIL=
VITE_USER_PASSWORD=
